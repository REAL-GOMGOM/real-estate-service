# ============================================================
# 내집(NAEZIP) 환경변수 샘플
# 이 파일은 Git에 커밋됩니다. 실제 값은 .env.local에 저장.
# ============================================================

# --- Phase 5f-lite: 카카오 오픈카톡 ---
# 비워두면 플로팅 버튼 + Footer 배너가 렌더링되지 않음 (intentional fail-safe)
NEXT_PUBLIC_KAKAO_OPENCHAT_URL=https://open.kakao.com/o/YOUR_ROOM_ID

# --- Phase 5d-1: 방문자 트래킹 ---
# SALT는 반드시 32자 이상 랜덤. 생성: openssl rand -hex 16
VISITOR_FINGERPRINT_SALT=generate-32-char-random-string-here
# 관리자 IP (선택). 쉼표 구분. 비워두면 모든 방문 카운트.
ADMIN_IP_ALLOWLIST=

# --- Phase 5d-2: Google Analytics ---
# GA4 Measurement ID (G-XXXXXXXXXX)
# 비워두면 GA4 스크립트가 로드되지 않음 (fail-safe)
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# --- Phase 5c-7 Stage 3.5: Google AdSense ---
# Publisher ID (ca-pub-XXXXXXXXXXXXXXXX). 비워두면 광고 로드 안 됨.
NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX
# Slot ID는 AdSense 승인 후 생성. 비워두면 placeholder 표시.
NEXT_PUBLIC_ADSENSE_SLOT_ARTICLE=
NEXT_PUBLIC_ADSENSE_SLOT_BOTTOM=
